# RENDER DEPLOYMENT CONFIGURATION
# Generar una clave segura en: https://djecrety.ir/
SECRET_KEY=django-insecure-cambiar-esto-en-render-con-una-clave-segura

# En producción debe ser False
DEBUG=False

# Reemplazar con tu dominio de Render: tuapp.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1,tuapp.onrender.com

# Base de datos PostgreSQL (Render la proporciona)
# Formato: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/ciudadconnect_db

# Google Maps API Key (opcional, dejar vacío si no lo usas)
GOOGLE_MAPS_API_KEY=
